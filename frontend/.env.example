# Samme nøkkelnavn lokalt (frontend/.env) og som build-env / build-args (Docker, Railway). Vite baker inn VITE_* ved build.

VITE_POSTHOG_ENABLED=false
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.i.posthog.com

VITE_API_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080/ws
VITE_TURNSTILE_SITE_KEY=0x4AAAAAABSTiPNZwrBLQkgr
VITE_MAPBOX_ACCESS_TOKEN=

# Railway: VITE_API_URL=https://…, VITE_WS_URL=wss://…/ws, VITE_TURNSTILE_SITE_KEY må matche backend TURNSTILE_SECRET_KEY.
