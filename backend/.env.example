# Samme nøkkelnavn lokalt (backend/.env) og i Railway → lim inn/ut fra dashboard etter behov.
# Spring: optional:file:.env (felles) og file:.env i dev-profil.

SPRING_PROFILES_ACTIVE=dev
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/krisefikser
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=root

JWT_SECRET=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
JWT_ACCESS_TOKEN_EXPIRATION=7200000
JWT_REFRESH_TOKEN_EXPIRATION=604800000

FRONTEND_URL=http://localhost:5173
# Docker med nginx på port 80: bruk http://localhost (uten :80).
TURNSTILE_SECRET_KEY=your_turnstile_secret_key
MAILTRAP_API_TOKEN=your_mailtrap_api_token
MAILTRAP_FROM=noreply@krisefikser.app

AUTH_ADMIN_TWO_FACTOR_ENABLED=true

# Railway: SPRING_PROFILES_ACTIVE=prod, JDBC fra MySQL-tjenesten (?sslMode=REQUIRED), FRONTEND_URL=https://ditt-domene (uten slash til slutt), PORT settes av Railway.
# Valgfritt: SPRING_JPA_HIBERNATE_DDL_AUTO=update
# Valgfritt: CLOUDINARY_URL=
# Kun Cypress full-stack mot dev,e2e: E2E_MAIL_HOOK_SECRET=... (ikke i prod)
