SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/krisefikser
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=root

# Minst 32 tegn — kortere verdi gir WeakKeyException ved oppstart (JJWT / HS256).
JWT_SECRET=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
JWT_ACCESS_TOKEN_EXPIRATION=7200000
JWT_REFRESH_TOKEN_EXPIRATION=604800000

# Må matche én kjørende Vite-origin (CORS). Bruk f.eks. http://localhost:5174 hvis 5173 er opptatt.
FRONTEND_URL=http://localhost:5173

# Hemmelig site key fra Cloudflare Turnstile → samme widget som site key i frontend (0x4AAAAAABSTiPNZwrBLQkgr).
# Legg til hostname (localhost, 127.0.0.1, ev. domenet ditt) under widget-innstillinger i Cloudflare.
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# Mailtrap Sending API token (registration sends verification email).
MAILTRAP_API_TOKEN=your_mailtrap_api_token

# Docker Compose (nginx): CORS — bruk http://localhost (ikke http://localhost:80).
# FRONTEND_URL=http://localhost
# TURNSTILE_SECRET_KEY over må være hemmeligheten for site key 0x4AAAAAABSTiPNZwrBLQkgr (samme som Docker-bygg bruker).
#
# Kun for automatiserte Cypress full-stack-tester (test-widget + dummy-token):
# VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA  (rot-.env før docker compose build)
# TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Full-stack Cypress (profile e2e): capture outbound mail in memory instead of Mailtrap.
# E2E_MAIL_HOOK_SECRET=your_random_secret
# SPRING_PROFILES_ACTIVE=dev,e2e